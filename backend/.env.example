# Backend Environment Setup

# API Configuration
GROQ_API_KEY=your_groq_api_key_here
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production

# Email Configuration (Optional - for OTP emails)
# If not configured, OTPs will be printed to console for development
EMAIL_SENDER=otp@drusti.online
EMAIL_PASSWORD=wdcfqvbmainsqpgs


# Database Configuration (Optional)
# Default uses SQLite: sqlite:///./startup_analyzer.db
# For PostgreSQL: postgresql://user:password@localhost/startup_analyzer
DATABASE_URL=sqlite:///./startup_analyzer.db

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Google OAuth (required for "Continue with Google" button)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
